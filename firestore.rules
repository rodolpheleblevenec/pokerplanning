rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{code} {
      // Lecture libre — code de 6 lettres difficile à brute-forcer
      allow read: if true;

      // Création uniquement avec la structure initiale correcte
      allow create: if request.resource.data.keys().hasAll(
          ['createdBy', 'status', 'participants', 'votes', 'revealed', 'createdAt']
        )
        && request.resource.data.status == 'waiting'
        && request.resource.data.revealed == false
        && request.resource.data.votes == {}
        && request.resource.data.participants == {};

      // Mise à jour uniquement sur rooms existantes, champs immuables protégés
      allow update: if resource != null
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt;

      // Suppression réservée à la Cloud Function
      allow delete: if false;
    }
  }
}
